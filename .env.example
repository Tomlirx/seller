# Postgres connection string (Neon, Vercel Postgres, or `npx prisma dev` for local dev)
DATABASE_URL="postgresql://user:password@localhost:5432/seller"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Vercel Blob (from your Vercel project's Blob storage settings)
BLOB_READ_WRITE_TOKEN=""

# Optional overrides for the seed script (defaults shown)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin12345"
